@model List<WorkoutDto>

<h2>My Workouts</h2>

<a asp-action="Create" class="btn btn-primary mb-3">Create Workout</a>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Date</th>
            <th>Total Calories</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var workout in Model)
        {
            <tr>
                <td>@workout.Name</td>
                <td>@workout.Date.ToShortDateString()</td>
                <td>@workout.TotalCalories</td>
                <td>
                    <a asp-action="Details" asp-route-id="@workout.Id" class="btn btn-info btn-sm">Details</a>
                    <a asp-action="Edit" asp-route-id="@workout.Id" class="btn btn-warning btn-sm">Edit</a>
                    <a asp-action="Delete" asp-route-id="@workout.Id" class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>